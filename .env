# ─────────────────────────────────────────────────────────────────────────────
# VARIABLES DE ENTORNO - MDM BACKEND
# Copia este archivo como .env y completa los valores ANTES de desplegar.
# NUNCA subas el .env real a Git.
# ─────────────────────────────────────────────────────────────────────────────

# Clave secreta para firmar JWT. Genera una con: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=315037952d558176551b60df84aa7044e9795d1ce6b03c1565c7d9c5dd391542

# Token del administrador para el panel web. Genera uno con el mismo comando.
MDM_ADMIN_TOKEN=62c63e8f01a4e2f2f50feb7ea8a043c8ae7cb6a00790c467ceef446a0b9f20e2

# Clave de registro que los dispositivos usan al enrolarse por primera vez.
MDM_REGISTRATION_KEY=1643a9c9cd864117d8a4f47a3b7a510a8d7d5223a3217462791391245147c718

# Base de datos (dejar vacío usa SQLite local, ideal para desarrollo)
# Para producción con PostgreSQL:
# DATABASE_URL=postgresql://usuario:password@host:5432/mdm_db

# Modo debug (true solo en desarrollo, NUNCA en producción)
FLASK_DEBUG=false
